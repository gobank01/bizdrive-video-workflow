# stacked-video — API keys (v88 BIZDRIVE)
#
# Copy this file to .env in this folder and fill in keys.
# .env is gitignored. Do NOT commit secrets.

# ---- STT (Speech-to-Text) ----
# ElevenLabs Scribe v2 — default for Thai content (best word-level timing)
# Get at https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=

# OpenAI Whisper — English fallback / vocabulary hint via --prompt
# OPENAI_API_KEY=

# xAI Grok — fast/free draft for English (phrase-level only)
# XAI_API_KEY=

# ---- B-roll providers (kept from v87) ----
# PEXELS_API_KEY=
# OPENROUTER_API_KEY=
