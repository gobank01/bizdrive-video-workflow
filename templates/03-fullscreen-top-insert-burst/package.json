{
  "name": "stacked-video",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npx --yes hyperframes@0.6.25 preview",
    "build:context60:test2": "node scripts/build-v34-context-cut.js",
    "build:context60:v35-full": "node scripts/build-v35-full-context-test.js",
    "auto:bgm": "node scripts/auto-final-bgm.js",
    "preflight": "bash scripts/clean-cut/preflight.sh",
    "install:vad": "bash scripts/clean-cut/install_vad.sh",
    "transcribe:el": "bash -lc 'set -a && source .env 2>/dev/null; set +a && export SSL_CERT_FILE=$(python3 -c \"import certifi; print(certifi.where())\") && python3 scripts/transcribe/transcribe.py'",
    "rough:cut:format": "python3 scripts/clean-cut/format_transcript.py",
    "rough:cut:padbleed": "python3 scripts/clean-cut/editorial_pass.py",
    "jump:cut:vad": "$HOME/.bizdrive/vad-env/bin/python3 scripts/clean-cut/vad_detect.py",
    "jump:cut:edl": "python3 scripts/clean-cut/speech_to_edl.py",
    "apply:edits": "python3 scripts/clean-cut/apply_edits.py",
    "check": "npx --yes hyperframes@0.6.25 lint && npx --yes hyperframes@0.6.25 validate && npx --yes hyperframes@0.6.25 inspect",
    "check:bgm": "node scripts/check-bgm-library.js",
    "check:caption-gold": "node scripts/check-caption-gold-spacing.js",
    "check:keyterms": "node scripts/check-keyterms.js",
    "check:motion": "node scripts/check-motion-safety.js",
    "check:transition": "node scripts/check-transition-mix.js",
    "finalize:video": "node scripts/finalize-video.js",
    "report:frames": "node scripts/frame-edit-report.js",
    "generate:broll": "node scripts/generate-openrouter-broll.js",
    "generate:broll:test-models": "node scripts/openrouter-broll-library.js",
    "mix:bgm": "node scripts/mix-bgm.js",
    "qa:timestamps": "node scripts/timestamp-qa-sheet.js",
    "qa:bgm": "node scripts/qa-bgm-final.js",
    "report:final": "node scripts/final-report.js",
    "select:bgm": "node scripts/select-bgm.js",
    "search:broll:test2-v35-full": "node scripts/pexels-test2-v35-full-broll.js",
    "search:broll:test2-context": "node scripts/pexels-test2-context-broll.js",
    "search:broll:pexels": "node scripts/pexels-broll-library.js",
    "render": "npx --yes hyperframes@0.6.25 render",
    "publish": "npx --yes hyperframes@0.6.25 publish"
  }
}
