# Raw source media library (large files; never commit)
/raw-media/

# Local-only sound-effects library (large; not part of the shareable repo)
/Sfx/

# Other top-level work folders not part of this repo
/robot/

# Longform pre-processor staging (large transcripts + symlinked source video)
/staging/

# Per-job work — local only, never shared (client content lives here)
/jobs/

